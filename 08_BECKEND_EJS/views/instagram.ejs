<!-- include will add head seacion the sub template sections -->
 <%- include("includes/head.ejs") %>
  <body>
    <h1>This page belongs to : @<%= data.name %></h1>
    <button>Follow</button>
    <p>
      Followers : <%= data.followers %> &nbsp; &nbsp; &nbsp; &nbsp; Following :
      <%= data.following %>
    </p>
    <hr>
    <!-- posts array -->
     <h4>Likes || comments || image</h4>


     <% for(post of data.posts){ %>
      <img src="<%= post.image%>" alt="some-images">
       <p>

      Likes : <%= post.likes %>
      &nbsp; &nbsp; &nbsp;
      Comments : <%= post.comments %>
      </p>

      <% } %>
    <button>Message</button> 
    <%- include("includes/footers.ejs") %>
  </body>
</html>
